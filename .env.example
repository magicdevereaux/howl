# Database
DATABASE_URL=postgresql://howl:howl_dev@127.0.0.1:5433/howl

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — optional; enables DALL-E avatar image generation
OPENAI_API_KEY=sk-proj-...

# App
ENVIRONMENT=development
DEBUG=true

# Frontend base URL — used in password-reset email links
FRONTEND_URL=http://localhost:3000

# Sentry — optional; omitting disables error/performance monitoring
SENTRY_DSN=https://...@sentry.io/...
